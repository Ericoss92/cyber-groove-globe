NODE_ENV=development
PORT=3001

# MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=soundwave
DB_PASSWORD=changeme
DB_NAME=soundwave_prod

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_64_hex_chars
JWT_REFRESH_SECRET=replace_me_with_another_64_hex_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173

# First admin (auto-promoted on init)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong
